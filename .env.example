# Copy this file to .env and fill in your own key. Never commit .env.

# Required: your own Anthropic API key, used only to run the Prescreen scorer
# and the simulated interview agent inside THIS sandbox. Not shared with
# HappyRecruiting, HappyRobot, or Ashby.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model used for scoring/interview simulation.
# Check https://docs.claude.com for the current model id if this one errors.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Real HappyRecruiting instance we read criteria/killer-questions/job-info/
# recruiter data FROM (read-only, GET requests only — see happyrecruiting.js).
HAPPYRECRUITING_BASE_URL=https://uirecruitingplatform-production.up.railway.app

PORT=3100
